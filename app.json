{
  "expo": {
    "name": "Hifz Tracker",
    "slug": "hifz-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "hifz-tracker",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.selhabti.hifztracker"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.selhabti.hifztracker"
    },
    "platforms": ["ios", "android", "web"],
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-image"
    ]
  }
}
